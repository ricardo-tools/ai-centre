# Local development (Docker Postgres — auto-started by npm run dev)
DATABASE_URL=postgresql://aicentre:aicentre@localhost:5433/aicentre
SKIP_AUTH=true

# Optional — set these for full feature testing:
# BLOB_READ_WRITE_TOKEN=     # Vercel Blob (uploads fall back to public/uploads/ without this)
# AUTH_SECRET=                # JWT signing (not needed with SKIP_AUTH=true)
# MAILGUN_API_KEY=            # Email (OTP logged to console without this)
# MAILGUN_DOMAIN=             # Email domain
# ANTHROPIC_API_KEY=          # Claude API (showcase generation)
# ADMIN_EMAIL=                # Auto-promote to admin on first login
