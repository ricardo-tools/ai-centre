# ─── Required ──────────────────────────────────────────────────────────────────
DATABASE_URL=              # Postgres connection string (Neon for prod, local for dev)
                           # Local dev: postgresql://aicentre:aicentre@localhost:5433/aicentre

# ─── Auth ──────────────────────────────────────────────────────────────────────
AUTH_SECRET=               # JWT signing secret (32+ chars) — REQUIRED in production
SKIP_AUTH=                 # Set to 'true' ONLY in local dev — bypasses auth entirely
ADMIN_EMAIL=               # (optional) Auto-promote this email to admin on first login

# ─── Email (OTP Login) ────────────────────────────────────────────────────────
MAILGUN_API_KEY=           # Mailgun API key for OTP email delivery
MAILGUN_DOMAIN=            # Mailgun sending domain
MAILGUN_FROM_EMAIL=        # (optional) Sender address — defaults to noreply@MAILGUN_DOMAIN
MAILGUN_EU=                # (optional) Set to 'true' for EU endpoint

# ─── Storage ──────────────────────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=     # Vercel Blob token (skill assets, generated ZIPs)

# ─── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=         # Claude API key for showcase generation
OPENROUTER_API_KEY=        # OpenRouter API key for chat assistant

# ─── Observability (future) ───────────────────────────────────────────────────
SENTRY_DSN=                # (optional) Sentry error tracking
